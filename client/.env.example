# Optional: override API base URL (production builds).
# Leave unset during local dev to use Vite proxy at `/api`.
# VITE_API_URL=http://localhost:5000/api

# Optional: API origin for hosted builds. The app appends `/api`.
# VITE_API_ORIGIN=http://localhost:5000

# Optional: backend target for Vite dev proxy (see `client/vite.config.js`)
# VITE_PROXY_TARGET=http://localhost:5000
