# ---------------------------------------------------------------------------
# Development: you can run `npm run dev` from the repo root with NO edits.
# - Leave MONGODB_URI unset → automatic in-memory MongoDB (data clears on exit).
# - Leave JWT_SECRET unset → a dev-only secret is applied automatically.
# ---------------------------------------------------------------------------

# Optional: real MongoDB (local, Docker, or Atlas). If set, in-memory DB is NOT used.
# MONGODB_URI=mongodb://127.0.0.1:27017/taskflow

PORT=5000
CLIENT_ORIGIN=http://localhost:5173

# Optional in development; required in production.
# JWT_SECRET=use_a_long_random_string_in_production

JWT_EXPIRES_IN=7d
